# Copy this file to .env and adjust as needed.
# .env is gitignored.

# PostgreSQL
POSTGRES_USER=habit
POSTGRES_PASSWORD=habit
POSTGRES_DB=habit_tracker
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# MongoDB
MONGO_USER=habit
MONGO_PASSWORD=habit
MONGO_HOST=localhost
MONGO_PORT=27017
